{
  "private": true,
  "name": "resharp3ds-studio-electron",
  "version": "1.0.0",
  "main": "lib/backend/electron-main.js",
  "dependencies": {
    "@theia/core": "1.72.3",
    "@theia/editor": "1.72.3",
    "@theia/electron": "1.72.3",
    "@theia/filesystem": "1.72.3",
    "@theia/markers": "1.72.3",
    "@theia/messages": "1.72.3",
    "@theia/monaco": "1.72.3",
    "@theia/navigator": "1.72.3",
    "@theia/preferences": "1.72.3",
    "@theia/process": "1.72.3",
    "@theia/terminal": "1.72.3",
    "@theia/workspace": "1.72.3",
    "resharp3ds-studio": "0.0.0"
  },
  "devDependencies": {
    "@theia/cli": "1.72.3",
    "electron": "39.8.7"
  },
  "scripts": {
    "bundle": "npm run rebuild && theia build --mode development",
    "rebuild": "theia rebuild:electron --cacheRoot ..",
    "start": "theia start",
    "watch": "npm run rebuild && theia build --watch --mode development"
  },
  "theia": {
    "target": "electron",
    "frontend": {
      "config": {
        "applicationName": "ReSharp3DS Studio",
        "defaultTheme": "dark"
      }
    },
    "electron": {
      "windowOptions": {
        "title": "ReSharp3DS Studio",
        "icon": "resources/resharp3ds.png"
      }
    }
  },
  "productName": "ReSharp3DS Studio",
  "build": {
    "appId": "dev.saysaa.resharp3ds.studio",
    "productName": "ReSharp3DS Studio",
    "asar": false,
    "directories": {
      "output": "dist"
    },
    "files": [
      "package.json",
      "lib/**/*",
      "src-gen/**/*",
      "resources/**/*",
      "node_modules/**/*",
      "!**/*.map"
    ],
    "extraResources": [
      {
        "from": "../resharp3ds-studio/compiler",
        "to": "resharp3ds-studio/compiler"
      }
    ],
    "linux": {
      "target": [
        "deb"
      ],
      "category": "Development",
      "executableName": "resharp3ds-studio",
      "icon": "resources/icons/linux",
      "synopsis": "ReSharp3DS Studio",
      "description": "IDE for ReSharp3DS development",
      "maintainer": "Saysaa <noreply@resharp3ds.local>",
      "vendor": "Saysaa",
      "artifactName": "ReSharp3DS-Studio-linux-x64.${ext}"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "resources/icons/windows/icon.ico",
      "artifactName": "ReSharp3DS-Studio-windows-x64-setup.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "ReSharp3DS Studio"
    }
  },
  "description": "IDE for ReSharp3DS development",
  "homepage": "https://github.com/saysaa/ReSharp3DS-Studio",
  "author": {
    "name": "Saysaa",
    "email": "noreply@resharp3ds.local"
  },
  "license": "GPL-3.0-only"
}
