{
  "private": true,
  "engines": {
    "node": ">=18",
    "npm": ">=8"
  },
  "scripts": {
    "build:browser": "npm --prefix browser-app run bundle",
    "build:electron": "npm --prefix electron-app run bundle",
    "prepare": "lerna run prepare",
    "postinstall": "theia check:theia-version",
    "start:browser": "npm --prefix browser-app start",
    "start:electron": "npm --prefix electron-app start",
    "watch:browser": "lerna run --parallel watch --ignore electron-app",
    "watch:electron": "lerna run --parallel watch --ignore browser-app",
    "dist:dir": "yarn clean:dist && yarn build:electron && electron-builder --projectDir electron-app --dir",
    "dist:linux": "yarn clean:dist && yarn build:electron && electron-builder --projectDir electron-app --linux deb --x64",
    "dist:win": "yarn clean:dist && yarn build:electron && electron-builder --projectDir electron-app --win nsis --x64",
    "clean:dist": "node -e \"require('fs').rmSync('electron-app/dist', { recursive: true, force: true })\""
  },
  "devDependencies": {
    "electron-builder": "26.0.12",
    "lerna": "2.4.0"
  },
  "workspaces": [
    "resharp3ds-studio",
    "browser-app",
    "electron-app"
  ],
  "license": "GPL-3.0-only"
}
